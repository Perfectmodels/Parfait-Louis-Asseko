# Firebase Configuration
# ⚠️ NE JAMAIS COMMITTER LES VRAIES VALEURS DANS GIT
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# FCM Push Notifications
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
# Firebase Console → Project Settings → Cloud Messaging → Server key (Legacy)
VITE_FCM_SERVER_KEY=your_fcm_server_key_here

# API Keys
# ⚠️ CES CLÉS SONT SENSIBLES - NE PAS EXPOSER DANS LES LOGS
VITE_IMGBB_API_KEY=your_imgbb_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary — VITE_ pour le client (cloud name seulement), sans VITE_ pour le serveur
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Variables serveur (Vercel API functions) — à configurer dans Vercel Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# Brevo — côté serveur uniquement (Vercel Dashboard)
BREVO_API_KEY=your-brevo-api-key

# Firebase Dynamic Links
VITE_FIREBASE_DYNAMIC_LINKS_API_KEY=your_dynamic_links_api_key_here
VITE_FIREBASE_DYNAMIC_LINKS_DOMAIN=your-app.page.link

# Application URL
VITE_APP_URL=https://perfectmodels.ga

# Dropbox Integration
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here
VITE_DROPBOX_APP_SECRET=your_dropbox_app_secret_here

# Environment
# Options: development, production
NODE_ENV=development
